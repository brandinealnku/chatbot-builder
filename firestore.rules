rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function ownsAccount(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if ownsAccount(userId);

      match /chatbots/{chatbotId} {
        allow read, write: if ownsAccount(userId);
      }

      match /leads/{leadId} {
        allow read, write: if ownsAccount(userId);
      }
    }

    match /publicChatbots/{chatbotId} {
      allow read: if true;
      allow create, update: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /publicLeads/{leadId} {
      allow create: if true;
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
